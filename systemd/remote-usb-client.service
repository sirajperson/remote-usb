[Unit]
Description=Remote USB client — attach local USB to a remote-usb server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# SERVER_IP = machine running `remote-usb serve`
ExecStartPre=/usr/local/bin/remote-usb prepare
ExecStart=/usr/local/bin/remote-usb attach SERVER_IP --auto --match 14cd:1212
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
